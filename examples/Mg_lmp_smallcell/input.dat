md_steps 4000
md_steps_adaption 0
md_script_interpreter python
md_script_filename  MyTm_MD_lammps.py
max_step 10 
max_sub_step 20 
method -1 6 0.35 0.5 5.0 
init_tem_check 1
supercell 3 3 6
bisection_relax_struct 1
solid_cutoff 0.8
liquid_cutoff 0.2


build liquid 1 0
size 1.0 1.0 0.5
pos 0.5 0.5 0.25
rot 0 0 0

run smallcell 500 1800
