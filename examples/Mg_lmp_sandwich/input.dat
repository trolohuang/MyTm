
md_steps 2000
md_steps_adaption 0
md_script_interpreter python
md_script_filename  ./MyTm_MD_lammps.py


solid_cutoff 0.8
liquid_cutoff 0.2
method -1 6 0.35 0.5 5.0

supercell 5 5 15
build liquid 1 0 
size 1.0 1.0 0.25
pos 0.5 0.5 0.125
rot 0 0 0
build liquid 1 0
size 1.0 1.0 0.25
pos 0.5 0.5 0.625
rot 0 0 0

max_step 20 
max_sub_step 20
init_tem_check 1
bisection_relax_struct 1
run bisection 500 1500 1 50
