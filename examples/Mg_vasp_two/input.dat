md_steps 2000
md_steps_adaption 0
md_script_interpreter bash
md_script_filename  ./MyTm_MD.sh
max_step 20 
max_sub_step 20 
method -1 6 0.35 0.5 5.0 
init_tem_check 1
supercell 4 4 8
bisection_relax_struct 1
solid_cutoff 0.8
liquid_cutoff 0.2


build liquid 1 0
size 1.0 1.0 0.5
pos 0.5 0.5 0.25
rot 0 0 0

run bisection 500 1500 1 100
