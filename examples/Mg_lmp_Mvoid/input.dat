
md_steps 20000
md_steps_adaption 1.0
md_script_interpreter python
md_script_filename  ./MyTm_MD_lammps.py


solid_cutoff 0.7
liquid_cutoff 0.2
method -1 6 0.35 0.5 5.0

supercell 4 4 20
build defect 1 0.8
size 1.0 1.0 0.2
pos 0.5 0.5 0.5
rot 0 0 0


max_step 40 
max_sub_step 4
init_tem_check 1
bisection_relax_struct 1
run bisection 2500 4500 2 0.1
